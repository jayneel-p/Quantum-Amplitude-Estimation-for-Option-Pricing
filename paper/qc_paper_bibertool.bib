  JOURNALTITLE = {Quantum},
  KEYWORDS = {Quantum Physics},
  LANGID = {english},
  PAGES = {1504},
  SHORTJOURNAL = {Quantum},
  TITLE = {Option Pricing under Stochastic Volatility on a Quantum Computer},
  URLDATE = {2026-04-15},
  VOLUME = {8},
}

